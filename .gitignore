# penrose runtime — never commit the brain or ingested artifacts
.brain/
.brainstore/
inbox/
archives/
logs/
backups/
.data_cache/
.embed_cache/
.holdout_burned
.holdout_burned.*.lock

# run artifacts (regenerated by `make run`)
reports/*.md
reports/proposals.jsonl
reports/proposals.jsonl.lock
dashboard/live.json
dashboard/connections.json
decisions.jsonl
principles.jsonl
review_queue.jsonl
runs.jsonl
backtest_ledger.tsv
backtest_ledger.tsv.lock
dream_runs.jsonl
dream_runs.jsonl.lock

# paper-specific P2 output (one claims.py per source; cold-start = none)
# P2 is LLM-driven in production — claims.py is operator-generated per paper
src/penrose/pipeline/claims.py

# paper-specific modules (cold-start registry starts empty)
# each module subdir is itself a build artifact of running on a specific paper
modules/*
!modules/__init__.py
!modules/_specs/
modules/_specs/

# papers dropped at root for testing (normally go in inbox/, also gitignored)
/*.pdf

# test papers directory (pull down PDFs to test the pipeline; never committed)
/test_papers/*
!/test_papers/.gitkeep

# operator credentials (copy .env.example to .env and populate locally)
.env
.dash-token

# LLM response cache (regenerable; can be large)
.llm_cache/

# Docker sandbox scratch (bind-mounted per auto-impl run; parquet/JSON IPC, always transient)
.sandbox_work/

*.pyc
__pycache__/
.venv/
.DS_Store

# iterate-loop snapshots (run output)
run_archive/

# reset archives (archived run+brain state)
reset_archive/
dashboard/progress.json
reports/charts/
reports/analysis_index.jsonl
reports/fidelity_rejections.jsonl
reports/fidelity_rejections.jsonl.lock
data_requests.jsonl
processed_papers.json
inbox_offdomain/
src/penrose/data/.databento_cache/
feedback.jsonl
chat_log/

# generated corpus artifact (rebuilt by corpus.build_files; dashboard reads it)
dashboard/corpus.json
